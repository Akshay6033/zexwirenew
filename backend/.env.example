# Database
DB_HOST=localhost
DB_USER=
DB_PASSWORD=
DB_NAME=

# User JWT (checkout tokens)
USER_JWT_SECRET=

# Frontend URL (PayPal return links)
FRONTEND_URL=http://localhost:5173

# Razorpay — live keys (default, same as legacy Razorpay_pay.php)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Test keys — only used for user ids in RAZORPAY_TEST_USER_IDS (legacy: 651,501,3331,2688)
RAZORPAY_TEST_KEY_ID=
RAZORPAY_TEST_KEY_SECRET=
RAZORPAY_TEST_USER_IDS=651,501,3331,2688

# Optional: set RAZORPAY_MODE=test to force test keys for ALL users (local dev only)
# RAZORPAY_MODE=test

# PayPal — live keys (default)
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# PayPal — sandbox keys (used for PAYPAL_TEST_USER_IDS, same as legacy user 2688 block)
PAYPAL_SANDBOX_CLIENT_ID=
PAYPAL_SANDBOX_CLIENT_SECRET=
PAYPAL_TEST_USER_IDS=651,501,3331,2688

# Optional: PAYPAL_MODE=sandbox forces sandbox for all users (local dev)

# Stripe — live keys (default, legacy application/config/stripe.php)
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=

# Stripe — test keys (STRIPE_TEST_USER_IDS)
STRIPE_TEST_PUBLISHABLE_KEY=
STRIPE_TEST_SECRET_KEY=
STRIPE_TEST_USER_IDS=651,501,3331,2688

# Optional: STRIPE_MODE=test forces test keys for all users (local dev)
